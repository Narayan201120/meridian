MERIDIAN_ENVIRONMENT=development
MERIDIAN_APP_NAME=Meridian API
MERIDIAN_APP_VERSION=0.1.0
MERIDIAN_API_V1_PREFIX=/api/v1
MERIDIAN_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres
